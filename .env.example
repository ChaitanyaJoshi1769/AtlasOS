# Atlas OS Environment Configuration

# Backend
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://atlas:password@localhost:5432/atlas
TIMESCALE_URL=postgresql://atlas:password@localhost:5432/atlas_timescale
REDIS_URL=redis://localhost:6379

# Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=atlas-data
S3_REGION=us-east-1

# Vector Database
QDRANT_URL=http://localhost:6333

# Streaming
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=atlas-consumers

# LLM APIs
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=

# AI Runtime
PYTHON_ENV=development
LANGGRAPH_DEBUG=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=development

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Observability
OTEL_ENABLED=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces
PROMETHEUS_PORT=9090

# Feature Flags
ENABLE_KNOWLEDGE_GRAPH=false
ENABLE_GOVERNANCE=false
ENABLE_ADVANCED_AGENTS=false
